{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "bootstrapVersion": {
      "const": 1,
      "type": "number"
    },
    "localDatabaseSchemaVersion": {
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer"
    },
    "streamId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "supportedProjectionVersions": {
      "additionalProperties": false,
      "properties": {
        "maximum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        },
        "minimum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        }
      },
      "required": [
        "minimum",
        "maximum"
      ],
      "type": "object"
    }
  },
  "required": [
    "bootstrapVersion",
    "streamId",
    "localDatabaseSchemaVersion",
    "supportedProjectionVersions"
  ],
  "type": "object",
  "x-data-classification": "C2"
}
