{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "generatedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "groups": {
      "additionalProperties": false,
      "properties": {
        "needsAttention": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "action": {
                "maxLength": 220,
                "minLength": 1,
                "type": "string"
              },
              "key": {
                "maxLength": 120,
                "minLength": 1,
                "type": "string"
              },
              "label": {
                "maxLength": 160,
                "minLength": 1,
                "type": "string"
              },
              "state": {
                "enum": [
                  "CONFIRMED",
                  "UNKNOWN",
                  "NEEDS_REVIEW",
                  "STALE",
                  "PROXY",
                  "NOT_APPLICABLE"
                ],
                "type": "string"
              }
            },
            "required": [
              "key",
              "label",
              "state",
              "action"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "optionalImprovements": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "key": {
                "maxLength": 120,
                "minLength": 1,
                "type": "string"
              },
              "label": {
                "maxLength": 160,
                "minLength": 1,
                "type": "string"
              },
              "state": {
                "enum": [
                  "CONFIRMED",
                  "UNKNOWN",
                  "NEEDS_REVIEW",
                  "STALE",
                  "PROXY",
                  "NOT_APPLICABLE"
                ],
                "type": "string"
              }
            },
            "required": [
              "key",
              "label",
              "state"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "ready": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "key": {
                "maxLength": 120,
                "minLength": 1,
                "type": "string"
              },
              "label": {
                "maxLength": 160,
                "minLength": 1,
                "type": "string"
              },
              "state": {
                "enum": [
                  "CONFIRMED",
                  "UNKNOWN",
                  "NEEDS_REVIEW",
                  "STALE",
                  "PROXY",
                  "NOT_APPLICABLE"
                ],
                "type": "string"
              }
            },
            "required": [
              "key",
              "label",
              "state"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "ready",
        "needsAttention",
        "optionalImprovements"
      ],
      "type": "object"
    },
    "planningContextRevision": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "plotId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    }
  },
  "required": [
    "plotId",
    "generatedAt",
    "planningContextRevision",
    "groups"
  ],
  "type": "object",
  "x-data-classification": "C3"
}
