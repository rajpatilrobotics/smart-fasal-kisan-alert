{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "items": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "accessVersion": {
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991,
            "type": "integer"
          },
          "consentDecisionId": {
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "type": "string"
          },
          "expiresAt": {
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
            "type": "string"
          },
          "purposeKey": {
            "enum": [
              "farmer.self_service",
              "case.expert_support",
              "field.visit",
              "sensor.maintenance",
              "assisted.service",
              "alert.delivery",
              "market.support",
              "data.rights"
            ],
            "type": "string"
          },
          "scopeKey": {
            "enum": [
              "location.processing",
              "audio.storage",
              "case.sharing",
              "sensor.collection",
              "sensor.maintenance_location",
              "visit.access",
              "assisted_service.access",
              "channel.app_push",
              "channel.sms",
              "channel.ivr",
              "market.private_fields"
            ],
            "type": "string"
          },
          "state": {
            "enum": [
              "MISSING",
              "ALLOWED",
              "DENIED",
              "EXPIRED",
              "WITHDRAWN"
            ],
            "type": "string"
          },
          "targetId": {
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "type": "string"
          },
          "targetKind": {
            "enum": [
              "ACCOUNT",
              "ASSISTED_FARMER_CONTEXT"
            ],
            "type": "string"
          }
        },
        "required": [
          "scopeKey",
          "purposeKey",
          "targetKind",
          "targetId",
          "state",
          "accessVersion"
        ],
        "type": "object"
      },
      "maxItems": 100,
      "type": "array"
    },
    "revision": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "items",
    "revision"
  ],
  "type": "object",
  "x-data-classification": "C2"
}
