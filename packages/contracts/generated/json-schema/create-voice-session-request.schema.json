{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "audioCapabilities": {
      "additionalProperties": false,
      "properties": {
        "httpsAudio": {
          "type": "boolean"
        },
        "offlineAudio": {
          "type": "boolean"
        },
        "realtime": {
          "type": "boolean"
        }
      },
      "required": [
        "realtime",
        "httpsAudio",
        "offlineAudio"
      ],
      "type": "object"
    },
    "contextIds": {
      "items": {
        "format": "uuid",
        "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
        "type": "string"
      },
      "maxItems": 8,
      "type": "array"
    },
    "language": {
      "enum": [
        "mr",
        "hi",
        "en"
      ],
      "type": "string"
    },
    "protocolVersion": {
      "const": 1,
      "type": "number"
    },
    "visualRoute": {
      "maxLength": 240,
      "minLength": 1,
      "pattern": "^\\/",
      "type": "string"
    }
  },
  "required": [
    "protocolVersion",
    "language",
    "visualRoute",
    "contextIds",
    "audioCapabilities"
  ],
  "type": "object",
  "x-data-classification": "C2"
}
