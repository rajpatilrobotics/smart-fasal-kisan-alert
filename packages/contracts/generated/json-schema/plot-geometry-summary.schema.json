{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "captureMethod": {
      "enum": [
        "GPS_POINT",
        "MANUAL_MAP",
        "VILLAGE_LANDMARK",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "geometryVersion": {
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer"
    },
    "gpsPermission": {
      "enum": [
        "GRANTED",
        "DENIED",
        "PROMPT",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "hasExactServerGeometry": {
      "type": "boolean"
    },
    "kind": {
      "enum": [
        "NONE",
        "POINT",
        "POLYGON",
        "VILLAGE_LANDMARK"
      ],
      "type": "string"
    },
    "recordedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    }
  },
  "required": [
    "geometryVersion",
    "kind",
    "captureMethod",
    "gpsPermission",
    "hasExactServerGeometry",
    "recordedAt"
  ],
  "type": "object",
  "x-data-classification": "C2"
}
