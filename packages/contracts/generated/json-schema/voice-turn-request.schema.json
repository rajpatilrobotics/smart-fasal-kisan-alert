{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "acknowledgedServerSequence": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "clientSequence": {
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer"
    },
    "input": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "text": {
              "maxLength": 2000,
              "minLength": 1,
              "type": "string"
            },
            "type": {
              "const": "TEXT",
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "bytesBase64": {
              "maxLength": 350000,
              "minLength": 4,
              "type": "string"
            },
            "mimeType": {
              "enum": [
                "audio/webm;codecs=opus",
                "audio/wav"
              ],
              "type": "string"
            },
            "sha256": {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            "type": {
              "const": "AUDIO",
              "type": "string"
            }
          },
          "required": [
            "type",
            "mimeType",
            "sha256",
            "bytesBase64"
          ],
          "type": "object"
        }
      ]
    },
    "turnId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    }
  },
  "required": [
    "turnId",
    "input",
    "clientSequence",
    "acknowledgedServerSequence"
  ],
  "type": "object",
  "x-data-classification": "C4"
}
