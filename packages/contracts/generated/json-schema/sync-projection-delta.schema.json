{
  "$defs": {
    "JsonValue": {}
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "authoritativeRevision": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "changeType": {
      "enum": [
        "UPSERT",
        "TOMBSTONE"
      ],
      "type": "string"
    },
    "dataMode": {
      "enum": [
        "LIVE",
        "RECORDED",
        "SIMULATED"
      ],
      "type": "string"
    },
    "payload": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "payloadChecksum": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "payloadClassification": {
      "enum": [
        "C0",
        "C1",
        "C2"
      ],
      "type": "string"
    },
    "projectionId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "projectionSchemaVersion": {
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer"
    },
    "projectionType": {
      "maxLength": 80,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "projectionType",
    "projectionId",
    "projectionSchemaVersion",
    "authoritativeRevision",
    "changeType",
    "dataMode",
    "payloadClassification",
    "payload",
    "payloadChecksum"
  ],
  "type": "object",
  "x-data-classification": "C2"
}
