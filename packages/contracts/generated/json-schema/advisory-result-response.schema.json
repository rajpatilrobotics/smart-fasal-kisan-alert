    "AdvisoryReason": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 80,
          "minLength": 1,
          "type": "string"
        },
        "contribution": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "label": {
          "maxLength": 180,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "code",
        "label",
        "contribution"
      ],
      "type": "object",
      "x-data-classification": "C3"
