{
  "$defs": {
    "JsonValue": {}
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "commandId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "expiresAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "payloadHash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "proposalId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "readBack": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "revision": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "sessionId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "state": {
      "enum": [
        "PENDING",
        "CONFIRMED",
        "CANCELLED",
        "SUPERSEDED",
        "EXPIRED",
        "EXECUTING",
        "COMPLETE",
        "FAILED"
      ],
      "type": "string"
    },
    "toolKey": {
      "maxLength": 120,
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "proposalId",
    "sessionId",
    "revision",
    "state",
    "toolKey",
    "payloadHash",
    "readBack",
    "expiresAt"
  ],
  "type": "object",
  "x-data-classification": "C3"
}
