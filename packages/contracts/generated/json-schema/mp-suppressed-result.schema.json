{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "methodologyId": {
      "maxLength": 120,
      "minLength": 1,
      "type": "string"
    },
    "reasonCode": {
      "enum": [
        "COHORT_TOO_SMALL",
        "COMPLEMENTARY_SUPPRESSION",
        "STICKY_SUPPRESSION"
      ],
      "type": "string"
    },
    "status": {
      "const": "SUPPRESSED",
      "type": "string"
    }
  },
  "required": [
    "status",
    "reasonCode",
    "methodologyId"
  ],
  "type": "object",
  "x-data-classification": "C1"
}
