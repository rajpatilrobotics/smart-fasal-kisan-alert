{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-fasal.example/contracts/health.schema.json",
  "title": "HealthPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "service",
    "status",
    "timestamp"
  ],
  "properties": {
    "service": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "not_ready"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
