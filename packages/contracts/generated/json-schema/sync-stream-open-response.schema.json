{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "acceptedClientEventVersions": {
      "additionalProperties": false,
      "properties": {
        "maximum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        },
        "minimum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        }
      },
      "required": [
        "minimum",
        "maximum"
      ],
      "type": "object"
    },
    "acceptedCommandVersions": {
      "additionalProperties": false,
      "properties": {
        "maximum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        },
        "minimum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        }
      },
      "required": [
        "minimum",
        "maximum"
      ],
      "type": "object"
    },
    "acceptedMediaVersions": {
      "additionalProperties": false,
      "properties": {
        "maximum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        },
        "minimum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        }
      },
      "required": [
        "minimum",
        "maximum"
      ],
      "type": "object"
    },
    "acceptedProjectionVersions": {
      "additionalProperties": false,
      "properties": {
        "maximum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        },
        "minimum": {
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991,
          "type": "integer"
        }
      },
      "required": [
        "minimum",
        "maximum"
      ],
      "type": "object"
    },
    "authorizationVersion": {
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991,
      "type": "integer"
    },
    "bootstrapRequired": {
      "type": "boolean"
    },
    "cursor": {
      "maxLength": 2048,
      "minLength": 1,
      "type": "string"
    },
    "maximumBatchBytes": {
      "maximum": 524288,
      "minimum": 1,
      "type": "integer"
    },
    "maximumBatchCommands": {
      "maximum": 100,
      "minimum": 1,
      "type": "integer"
    },
    "scope": {
      "const": "FARMER_SELF_SERVICE",
      "type": "string"
    },
    "serverTime": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$",
      "type": "string"
    },
    "serverTimeSignature": {
      "maxLength": 2048,
      "minLength": 16,
      "type": "string"
    },
    "stakeholder": {
      "const": "FARMER",
      "type": "string"
    },
    "streamId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    },
    "subjectDeviceBindingId": {
      "format": "uuid",
      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
      "type": "string"
    }
  },
  "required": [
    "streamId",
    "subjectDeviceBindingId",
    "stakeholder",
    "scope",
    "authorizationVersion",
    "acceptedCommandVersions",
    "acceptedClientEventVersions",
    "acceptedProjectionVersions",
    "acceptedMediaVersions",
    "maximumBatchCommands",
    "maximumBatchBytes",
    "serverTime",
    "serverTimeSignature",
    "cursor",
    "bootstrapRequired"
  ],
  "type": "object",
  "x-data-classification": "C2"
}
