{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cropName": {
      "maxLength": 120,
      "minLength": 1,
      "type": "string"
    },
    "notes": {
      "maxLength": 500,
      "type": "string"
    },
    "seasonLabel": {
      "maxLength": 120,
      "minLength": 1,
      "type": "string"
    },
    "year": {
      "maximum": 2100,
      "minimum": 2000,
      "type": "integer"
    }
  },
  "required": [
    "cropName",
    "seasonLabel",
    "year"
  ],
  "type": "object",
  "x-data-classification": "C3"
}
