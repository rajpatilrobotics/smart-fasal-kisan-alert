{
  "name": "@smart-fasal/farmer-web",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build && node ./scripts/build-service-worker.mjs",
    "start": "next start --port 3000",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@smart-fasal/browser-auth": "workspace:*",
    "@smart-fasal/contracts": "workspace:*",
    "@smart-fasal/health": "workspace:*",
    "@smart-fasal/i18n": "workspace:*",
    "@smart-fasal/offline": "workspace:*",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "esbuild": "0.28.1",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "workbox-build": "7.4.1",
    "workbox-core": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1"
  }
}
