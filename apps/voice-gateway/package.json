{
  "name": "@smart-fasal/voice-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@fastify/websocket": "11.3.0",
    "@smart-fasal/config": "workspace:*",
    "@smart-fasal/contracts": "workspace:*",
    "@smart-fasal/service-runtime": "workspace:*",
    "@smart-fasal/voice": "workspace:*",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/ws": "8.18.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "ws": "8.21.0"
  }
}
