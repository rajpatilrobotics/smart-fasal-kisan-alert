# Local development defaults only. Copy to an ignored .env file and override per service.
# Never place production identifiers, credentials, tokens, phone numbers, or private data here.

NODE_ENV=development
LOG_LEVEL=debug

# Override these for each process. Ports must remain distinct when services run together.
SERVICE_NAME=domain-api
HOST=127.0.0.1
PORT=8080
SMART_FASAL_ENVIRONMENT=local

# Each browser build has its own exact origin and Firebase App ID.
FARMER_WEB_ORIGIN=http://localhost:3000
RSK_WEB_ORIGIN=http://localhost:3001
MP_WEB_ORIGIN=http://localhost:3002
FARMER_FIREBASE_APP_ID=
RSK_FIREBASE_APP_ID=
MP_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
STAFF_MFA_MAX_AGE_SECONDS=900
# Milestone 5 Recommendation evidence mode.
# recorded_raigad = demo-ready retained Raigad evidence.
# live_unavailable = no fake data; return typed unavailable/needs-input until real providers exist.
RECOMMENDATION_EVIDENCE_MODE=recorded_raigad

# Browser builds receive only public service origins and build metadata.
NEXT_PUBLIC_DOMAIN_API_ORIGIN=http://localhost:8080
NEXT_PUBLIC_MP_QUERY_API_ORIGIN=http://localhost:8084
NEXT_PUBLIC_CLIENT_BUILD=local-development

# Firebase Web configuration contains public, deployment-restricted identifiers only. Each
# surface has a separate prefix so one build cannot accidentally receive another app's identity
# configuration. Leave the values empty to show the truthful provider-unavailable state locally.
NEXT_PUBLIC_FARMER_SMART_FASAL_ENVIRONMENT=local
NEXT_PUBLIC_FARMER_FIREBASE_API_KEY=
NEXT_PUBLIC_FARMER_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FARMER_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FARMER_FIREBASE_APP_ID=
NEXT_PUBLIC_FARMER_FIREBASE_APPCHECK_ENTERPRISE_SITE_KEY=
NEXT_PUBLIC_RSK_SMART_FASAL_ENVIRONMENT=local
NEXT_PUBLIC_RSK_FIREBASE_API_KEY=
NEXT_PUBLIC_RSK_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_RSK_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_RSK_FIREBASE_APP_ID=
NEXT_PUBLIC_RSK_FIREBASE_APPCHECK_ENTERPRISE_SITE_KEY=
NEXT_PUBLIC_MP_SMART_FASAL_ENVIRONMENT=local
NEXT_PUBLIC_MP_FIREBASE_API_KEY=
NEXT_PUBLIC_MP_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_MP_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_MP_FIREBASE_APP_ID=
NEXT_PUBLIC_MP_FIREBASE_APPCHECK_ENTERPRISE_SITE_KEY=

# Matches the loopback-only PostgreSQL service in compose.yaml.
DATABASE_URL=postgresql://smart_fasal:local_smart_fasal@127.0.0.1:5432/smart_fasal

# Domain API runtime connections are injected as secrets. Their login principals must be allowed
# to SET LOCAL ROLE only to the matching non-login API role; leave blank for typed Unavailable.
FARMER_DATABASE_URL=
RSK_DATABASE_URL=
AUTH_STATE_DATABASE_URL=
RETURN_STATE_HMAC_SECRET=

# Domain Worker uses a separate login that can SET LOCAL ROLE only to sf_domain_worker. The M1
# process stays not-ready and does not claim outbox work until a real publisher is injected.
DOMAIN_WORKER_DATABASE_URL=

# Firebase Admin uses Application Default Credentials. Do not add service-account key paths,
# token values, unrestricted credentials, or private keys to this file.
# mp-query-api intentionally has no DATABASE_URL and reads no operational database.
